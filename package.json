{
  "name": "portfolio",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build && cp dist/index.html dist/404.html",
    "dev": "vite",
    "deploy": "npm run build && gh-pages -d dist",
    "deploy:site": "npm run build && mkdir -p .pages-deploy/docs && cp -r dist/* .pages-deploy/docs/ && npx gh-pages -d .pages-deploy -r https://github.com/raqper/raqper.github.io.git -b main && rm -rf .pages-deploy"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-icons": "^5.5.0",
    "react-router": "7.13.0",
    "react-simple-maps": "^3.0.0",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8"
  },
  "overrides": {
    "d3-color": "3.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "4.7.0",
    "gh-pages": "^6.2.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
    "vite": "6.4.1"
  }
}
